<view class="custom-tab-bar">
  <view class="login-tip-bar" wx:if="{{!isLoggedIn}}" bindtap="goLogin">
    <view class="login-tip-content">
      <text class="login-tip-text">{{isGuest ? '当前为游客模式，登录后可同步订单、收藏和账号信息' : '未登录，登录后可解锁更多功能'}}</text>
      <text class="login-tip-action">去登录</text>
    </view>
  </view>

  <view class="tab-list">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text class="tab-text">{{item.text}}</text>
    </view>
  </view>
</view>
