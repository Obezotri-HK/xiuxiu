.custom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: calc(74rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #eef2f7;
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 30rpx;
  line-height: 1;
  color: #6b7280;
}

.tab-item.active .tab-text {
  color: #10b981;
  font-weight: 700;
}
