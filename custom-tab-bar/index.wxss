.custom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border-top: 1rpx solid #eef2f7;
  box-sizing: border-box;
}

.login-tip-bar {
  padding: 16rpx 24rpx 12rpx;
  background: linear-gradient(90deg, #ecfdf5 0%, #f0fdf4 100%);
  border-bottom: 1rpx solid #eef2f7;
}

.login-tip-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.login-tip-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.4;
  color: #065f46;
}

.login-tip-action {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #10b981;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.tab-list {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: calc(74rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 30rpx;
  line-height: 1;
  color: #6b7280;
}

.tab-item.active .tab-text {
  color: #10b981;
  font-weight: 700;
}
