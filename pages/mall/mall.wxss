/* 商城容器 */
.mall-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(74rpx + env(safe-area-inset-bottom));
  background: #F7F8FA;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 32rpx;
  background: #ffffff;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #F3F4F6;
  border-radius: 48rpx;
  padding: 16rpx 28rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

/* 分类导航 */
.category-scroll {
  background: #ffffff;
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 40rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 24rpx;
  color: #6B7280;
}

.category-item.active .category-name {
  color: #10B981;
  font-weight: 600;
}

/* 横幅 */
.banner {
  margin: 24rpx 32rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 商品列表 */
.product-list {
  flex: 1;
  padding: 0 32rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.product-card {
  width: calc(50% - 12rpx);
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.product-img {
  width: 100%;
  height: 320rpx;
}

.product-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.product-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-wrapper {
  display: flex;
  align-items: flex-end;
}

.price-sign {
  font-size: 24rpx;
  color: #EF4444;
  font-weight: 600;
  margin-right: 4rpx;
}

.price-num {
  font-size: 36rpx;
  color: #EF4444;
  font-weight: 600;
}

.sales-text {
  font-size: 22rpx;
  color: #9CA3AF;
}
