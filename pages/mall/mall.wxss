/* 商城容器 */
.mall-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(138rpx + env(safe-area-inset-bottom));
  background: #F7F8FA;
  width: 100%;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #ffffff;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #F3F4F6;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

/* 分类导航 */
.category-scroll {
  background: #ffffff;
  white-space: nowrap;
  width: 100%;
}

.category-bar {
  display: inline-flex;
  padding: 16rpx 24rpx;
  gap: 24rpx;
  width: auto;
}

.category-item {
  text-align: center;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.category-text {
  font-size: 28rpx;
  color: #888888;
  font-weight: 500;
}

.category-item.active .category-text {
  color: #10B981;
  font-weight: 600;
}

/* 商品列表 */
.product-list {
  flex: 1;
  padding: 24rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 100%;
}

.product-card {
  width: calc(50% - 12rpx);
  max-width: calc(50% - 12rpx);
  background: #ffffff;
  border-radius: 20rpx;
  position: relative;
  transition: all 0.2s;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  height: auto;
}

.product-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  position: relative;
  width: 100%;
}

.product-img {
  width: 100%;
  height: 320rpx;
}

.favorite-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  z-index: 10;
}

.favorite-icon {
  font-size: 36rpx;
  opacity: 0.6;
  transition: all 0.2s;
}

.favorite-icon.active {
  opacity: 1;
}

.product-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.product-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  min-height: 180rpx;
}

.product-name {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-wrapper {
  display: flex;
  align-items: flex-end;
}

.price-sign {
  font-size: 24rpx;
  color: #FF4757;
  font-weight: 700;
  margin-right: 2rpx;
}

.price-num {
  font-size: 36rpx;
  color: #FF4757;
  font-weight: 700;
}

.sales-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}
