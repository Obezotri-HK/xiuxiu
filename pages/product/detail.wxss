page {
  background-color: #F5F7FA;
  min-height: 100vh;
}

.product-detail {
  padding-bottom: 120rpx;
}

.product-swiper {
  width: 100%;
  height: 560rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.product-header {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.tag-wrapper {
  margin-bottom: 16rpx;
}

.tag {
  display: inline-block;
  background-color: #FF6B6B;
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.product-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.product-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.current-price {
  display: flex;
  align-items: baseline;
  color: #FF6B6B;
}

.price-sign {
  font-size: 28rpx;
  font-weight: 600;
}

.price-num {
  font-size: 48rpx;
  font-weight: 700;
}

.original-price {
  font-size: 26rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 20rpx;
}

.spec-section, .quantity-section, .detail-section, .policy-section {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.required {
  color: #FF6B6B;
  margin-left: 8rpx;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #F5F7FA;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
}

.spec-item.selected {
  background-color: #FFF0F0;
  border-color: #FF6B6B;
}

.spec-name {
  font-size: 28rpx;
  color: #1A1A1A;
  margin-right: 16rpx;
}

.spec-price {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F7FA;
  border-radius: 8rpx;
  font-size: 36rpx;
  color: #333333;
}

.qty-value {
  width: 120rpx;
  text-align: center;
  font-size: 32rpx;
  color: #1A1A1A;
  margin: 0 20rpx;
}

.stock-text {
  font-size: 26rpx;
  color: #999999;
  margin-left: 32rpx;
}

.detail-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.policy-content {
  background-color: #FFFBE6;
  padding: 24rpx;
  border-radius: 12rpx;
}

.policy-text {
  display: block;
  font-size: 26rpx;
  color: #8B6914;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.policy-text:last-child {
  margin-bottom: 0;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bottom-left {
  display: flex;
  width: 200rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  position: relative;
}

.icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
  transition: all 0.3s ease;
}

.icon.active {
  transform: scale(1.3);
  filter: drop-shadow(0 0 8rpx rgba(239, 68, 68, 0.6));
}

.icon-text {
  font-size: 22rpx;
  color: #666666;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #EF4444;
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.bottom-right {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.btn-cart {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFB347;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.btn-buy {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FF6B6B;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}