.order-list-container {
  min-height: 100vh;
  background: #F7F8FA;
}

.type-tabs {
  display: flex;
  background: #ffffff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  position: relative;
}

.type-tab.active .type-tab-text {
  color: #10B981;
  font-weight: 600;
}

.type-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #10B981;
  border-radius: 3rpx;
}

.type-tab-text {
  font-size: 28rpx;
  color: #4B5563;
}

.order-list {
  height: calc(100vh - 100rpx);
}

.order-card {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-id {
  font-size: 24rpx;
  color: #9CA3AF;
}

.order-status {
  font-size: 28rpx;
  font-weight: 600;
}

.order-items {
  border-top: 1rpx dashed #F3F4F6;
  border-bottom: 1rpx dashed #F3F4F6;
  padding: 20rpx 0;
}

.order-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-item:last-child {
  margin-bottom: 0;
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #1F2937;
  display: block;
  margin-bottom: 8rpx;
}

.item-price {
  font-size: 26rpx;
  color: #EF4444;
}

.item-quantity {
  font-size: 26rpx;
  color: #9CA3AF;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.order-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.order-right {
  display: flex;
  align-items: center;
}

.order-total {
  font-size: 28rpx;
  color: #EF4444;
  font-weight: 600;
  margin-right: 24rpx;
}

.order-actions {
  display: flex;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: 1rpx solid #10B981;
  color: #10B981;
}

.action-btn:active {
  background: rgba(16, 185, 129, 0.1);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}