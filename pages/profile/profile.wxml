<view class="profile-container">
  <view class="user-section">
    <view class="user-avatar" bindtap="{{isLoggedIn ? '' : 'onLogin'}}">
      <text class="avatar-icon" wx:if="{{!userInfo || !userInfo.avatarUrl}}">👤</text>
      <image wx:if="{{userInfo && userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    </view>
    <view class="user-info">
      <text class="user-name">{{userName}}</text>
      <text class="user-desc">{{isLoggedIn ? '探索桂林山水之美' : '登录后享受更多服务'}}</text>
    </view>
    <view class="login-btn" wx:if="{{!isLoggedIn}}" bindtap="onLogin">
      <text class="login-text">登录</text>
    </view>
  </view>

  <view class="order-section" wx:if="{{isLoggedIn}}">
    <view class="order-header" bindtap="onMyOrders">
      <text class="order-title">我的订单</text>
      <view class="order-more">
        <text class="order-more-text">全部订单</text>
        <text class="order-arrow">›</text>
      </view>
    </view>
    <view class="order-stats">
      <view 
        class="order-stat-item" 
        wx:for="{{orderStats}}" 
        wx:key="id"
        bindtap="onOrderTap"
        data-type="{{item.id}}"
      >
        <view class="order-stat-icon">{{item.icon}}</view>
        <text class="order-stat-name">{{item.name}}</text>
        <view class="order-stat-count" wx:if="{{item.count > 0}}">{{item.count}}</view>
      </view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="onMyOrders">
      <view class="menu-left">
        <text class="menu-icon">📦</text>
        <text class="menu-text">我的订单</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMyFavorites">
      <view class="menu-left">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onHistory">
      <view class="menu-left">
        <text class="menu-icon">👁️</text>
        <text class="menu-text">浏览历史</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onContactService">
      <view class="menu-left">
        <text class="menu-icon">💬</text>
        <text class="menu-text">联系客服</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="onSettings">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAgreement">
      <view class="menu-left">
        <text class="menu-icon">📄</text>
        <text class="menu-text">用户协议</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onPrivacy">
      <view class="menu-left">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私政策</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="onLogout">
    <text class="logout-text">退出登录</text>
  </view>
</view>