.privacy-container {
  min-height: 100vh;
  background: #F0F7F4;
}

.privacy-content {
  padding: 40rpx 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E50;
  text-align: center;
  margin-bottom: 20rpx;
}

.update-time {
  display: block;
  font-size: 24rpx;
  color: #7F8C8D;
  text-align: center;
  margin-bottom: 48rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.section-content {
  display: block;
  font-size: 28rpx;
  color: #7F8C8D;
  line-height: 2;
}

.bottom-space {
  height: 60rpx;
}
