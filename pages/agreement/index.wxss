.agreement-container {
  min-height: 100vh;
  background: #F7F8FA;
}

.agreement-content {
  height: 100vh;
  padding: 32rpx;
}

.agreement-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
  text-align: center;
  margin-bottom: 48rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
}

.section-content {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
}

.section-content text {
  display: block;
  margin-bottom: 16rpx;
}