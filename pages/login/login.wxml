<view class="login-container">
  <view class="login-header">
    <view class="logo-wrapper">
      <text class="logo-icon">🚗</text>
    </view>
    <text class="app-name">绣绣AI</text>
    <text class="app-slogan">智能出行助手</text>
  </view>

  <view class="login-content">
    <view class="tabs">
      <view class="tab-item {{activeTab === 'phone' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="phone">
        <text class="tab-text">手机号登录</text>
      </view>
      <view class="tab-item {{activeTab === 'wechat' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="wechat">
        <text class="tab-text">微信授权</text>
      </view>
    </view>

    <view class="tab-content">
      <block wx:if="{{activeTab === 'phone'}}">
        <view class="form-group">
          <view class="input-wrapper">
            <text class="input-icon">📱</text>
            <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="input-placeholder" value="{{phone}}" bindinput="onPhoneInput"/>
          </view>
        </view>

        <view class="form-group">
          <view class="input-wrapper code-wrapper">
            <text class="input-icon">🔐</text>
            <input class="form-input code-input" type="number" maxlength="6" placeholder="请输入验证码" placeholder-class="input-placeholder" value="{{code}}" bindinput="onCodeInput"/>
            <view class="send-code-btn {{countdown > 0 ? 'send-code-disabled' : ''}}" bindtap="sendCode">
              <text wx:if="{{countdown > 0}}">{{countdown}}s后重发</text>
              <text wx:else>获取验证码</text>
            </view>
          </view>
        </view>

        <view class="btn btn-primary" bindtap="phoneLogin">
          <text class="btn-text">登录 / 注册</text>
        </view>
      </block>

      <block wx:else>
        <view class="wechat-tip">
          <text class="tip-icon">💡</text>
          <text class="tip-text">使用微信手机号快速登录，安全便捷</text>
        </view>

        <button class="btn btn-wechat" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          <text class="btn-icon">📱</text>
          <text class="btn-text">微信手机号授权登录</text>
        </button>
      </block>
    </view>

    <view class="divider-row">
      <view class="divider-line"></view>
      <text class="divider-text">其他登录方式</text>
      <view class="divider-line"></view>
    </view>

    <view class="btn btn-guest" bindtap="guestLogin">
      <text class="btn-icon">👤</text>
      <text class="btn-text">游客体验（剩余50次）</text>
    </view>

    <view class="agreement">
      <view class="checkbox {{agreed ? 'checkbox-checked' : ''}}" bindtap="toggleAgreement">
        <text wx:if="{{agreed}}" class="check-icon">✓</text>
      </view>
      <text class="agreement-text">登录即表示同意</text>
      <text class="agreement-link" bindtap="goToAgreement">《用户协议》</text>
      <text class="agreement-text">和</text>
      <text class="agreement-link" bindtap="goToPrivacy">《隐私政策》</text>
    </view>
  </view>
</view>
