.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #E3F2FD 50%, #F0F7F4 100%);
  padding: 60rpx 60rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-wrapper {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #2ECC71 0%, #3498DB 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx auto;
  box-shadow: 0 10rpx 40rpx rgba(46, 204, 113, 0.3);
}

.logo-icon {
  font-size: 70rpx;
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.app-slogan {
  display: block;
  font-size: 26rpx;
  color: #7F8C8D;
  letter-spacing: 4rpx;
  line-height: 1.5;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 60rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 52rpx;
  transition: all 0.3s ease;
}

.tab-active {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.3);
}

.tab-text {
  font-size: 28rpx;
  color: #7F8C8D;
  font-weight: 500;
}

.tab-active .tab-text {
  color: #ffffff;
  font-weight: 600;
}

.tab-content {
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(46, 204, 113, 0.2);
  border-radius: 24rpx;
  padding: 0 28rpx;
  height: 100rpx;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  color: #2ECC71;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #2C3E50;
}

.input-placeholder {
  color: #BDC3C7;
}

.code-wrapper {
  padding-right: 16rpx;
}

.code-input {
  flex: 1;
}

.send-code-btn {
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.send-code-disabled {
  background: rgba(189, 195, 199, 0.3);
  color: #BDC3C7;
}

.wechat-tip {
  display: flex;
  align-items: flex-start;
  background: rgba(46, 204, 113, 0.08);
  border: 2rpx solid rgba(46, 204, 113, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #7F8C8D;
  line-height: 1.6;
}

.btn {
  width: 100%;
  min-height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
  border: none;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.btn::after {
  border: none;
  outline: none;
}

button.btn {
  line-height: 1.4;
  padding-top: 0;
  padding-bottom: 0;
}

.btn-primary {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.3);
}

.btn-wechat {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.3);
}

.btn-guest {
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(46, 204, 113, 0.2);
  color: #2C3E50;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.btn-text {
  font-size: 30rpx;
  white-space: nowrap;
}

.divider-row {
  display: flex;
  align-items: center;
  margin: 20rpx 0 32rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(46, 204, 113, 0.2);
}

.divider-text {
  font-size: 24rpx;
  color: #BDC3C7;
  margin: 0 24rpx;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: auto;
  padding-top: 32rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid rgba(46, 204, 113, 0.3);
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox-checked {
  background: #2ECC71;
  border-color: #2ECC71;
}

.check-icon {
  font-size: 24rpx;
  color: #ffffff;
}

.agreement-text {
  font-size: 24rpx;
  color: #7F8C8D;
}

.agreement-link {
  font-size: 24rpx;
  color: #27AE60;
}
