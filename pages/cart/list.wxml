<view class="cart-container">
  <scroll-view class="cart-list" scroll-y>
    <view class="cart-header">
      <text class="header-title">购物车</text>
      <text class="clear-btn" bindtap="onClearCart">清空</text>
    </view>

    <view class="cart-items" wx:if="{{cartItems.length > 0}}">
      <view 
        class="cart-item" 
        wx:for="{{cartItems}}" 
        wx:key="index"
      >
        <view class="item-checkbox" bindtap="onItemSelect" data-index="{{index}}">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
        </view>

        <view class="item-content" bindtap="onProductTap" data-item="{{item}}">
          <image class="item-image" src="{{item.image}}" mode="aspectFill" />
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-spec">{{item.spec}}</text>
            <view class="item-bottom">
              <view class="item-price">
                <text class="price-sign">¥</text>
                <text class="price-num">{{item.price}}</text>
              </view>
              <view class="quantity-control">
                <view class="qty-btn" bindtap="onQuantityChange" data-index="{{index}}" data-delta="-1">
                  <text>-</text>
                </view>
                <text class="qty-value">{{item.quantity}}</text>
                <view class="qty-btn" bindtap="onQuantityChange" data-index="{{index}}" data-delta="1">
                  <text>+</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="item-delete" bindtap="onRemove" data-index="{{index}}">
          <text class="delete-icon">✕</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{cartItems.length === 0}}">
      <text class="empty-icon">🛒</text>
      <text class="empty-text">购物车是空的</text>
      <view class="empty-btn" bindtap="goMall">
        <text>去逛逛</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar" wx:if="{{cartItems.length > 0}}">
    <view class="select-all" bindtap="onSelectAll">
      <view class="checkbox {{selectedAll ? 'checked' : ''}}">
        <text wx:if="{{selectedAll}}">✓</text>
      </view>
      <text class="select-text">全选</text>
    </view>
    <view class="total-section">
      <text class="total-label">合计：</text>
      <view class="total-price">
        <text class="price-sign">¥</text>
        <text class="price-num">{{totalPrice}}</text>
      </view>
    </view>
    <view class="checkout-btn" bindtap="onCheckout">
      <text>结算 ({{totalCount}})</text>
    </view>
  </view>
</view>