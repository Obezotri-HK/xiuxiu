page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.cart-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.cart-list {
  flex: 1;
  height: calc(100vh - 120rpx);
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  background-color: #fff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  font-size: 28rpx;
  color: #999;
}

.cart-items {
  padding: 0 0 140rpx;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  background-color: #fff;
  margin-bottom: 16rpx;
  padding: 24rpx 32rpx;
}

.item-checkbox {
  padding-right: 20rpx;
  padding-top: 40rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background-color: #FF6B6B;
  border-color: #FF6B6B;
}

.checkbox.checked text {
  color: #fff;
  font-size: 24rpx;
}

.item-content {
  flex: 1;
  display: flex;
  padding-right: 20rpx;
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-left: 20rpx;
  padding-top: 4rpx;
}

.item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-spec {
  font-size: 24rpx;
  color: #999;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  display: flex;
  align-items: baseline;
}

.item-price .price-sign {
  font-size: 24rpx;
  color: #FF6B6B;
}

.item-price .price-num {
  font-size: 36rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.quantity-control {
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 24rpx;
  padding: 4rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #fff;
  border: 1rpx solid #eee;
}

.qty-btn text {
  font-size: 32rpx;
  color: #666;
}

.qty-value {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.item-delete {
  padding-top: 40rpx;
}

.delete-icon {
  font-size: 32rpx;
  color: #ccc;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.empty-btn {
  padding: 20rpx 80rpx;
  background-color: #FF6B6B;
  border-radius: 40rpx;
}

.empty-btn text {
  font-size: 30rpx;
  color: #fff;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all .checkbox {
  margin-right: 12rpx;
}

.select-text {
  font-size: 28rpx;
  color: #333;
}

.total-section {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  display: flex;
  align-items: baseline;
  margin-left: 8rpx;
}

.total-price .price-sign {
  font-size: 28rpx;
  color: #FF6B6B;
}

.total-price .price-num {
  font-size: 44rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.checkout-btn {
  padding: 24rpx 48rpx;
  background-color: #FF6B6B;
  border-radius: 44rpx;
}

.checkout-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}