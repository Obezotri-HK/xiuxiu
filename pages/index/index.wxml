<view class="chat-container">
  <!-- 顶部区域 -->
  <view class="chat-header">
    <view class="header-left">
      <text class="header-title">绣绣AI</text>
    </view>
    <view class="header-right">
      <view class="header-btn" bindtap="newChat">
        <text class="header-icon">+</text>
        <text class="header-text">新对话</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view 
    class="chat-messages" 
    scroll-y 
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    bounces="{{false}}"
  >
    <!-- 空状态提示 -->
    <view class="empty-state" wx:if="{{messageList.length === 0 && !isLoading}}">
      <view class="empty-icon">🤖</view>
      <view class="empty-title">你好，我是绣绣AI</view>
      <view class="empty-desc">你的智能出行助手，可以帮你规划桂林旅游路线、推荐景点、解答问题等</view>
      <view class="quick-prompts">
        <view class="prompt-item" bindtap="sendPrompt" data-prompt="推荐一条桂林三日游路线">
          <text class="prompt-text">推荐一条桂林三日游路线</text>
        </view>
        <view class="prompt-item" bindtap="sendPrompt" data-prompt="阳朔有什么好玩的景点？">
          <text class="prompt-text">阳朔有什么好玩的景点？</text>
        </view>
        <view class="prompt-item" bindtap="sendPrompt" data-prompt="桂林美食推荐">
          <text class="prompt-text">桂林美食推荐</text>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view class="message-list">
      <view 
        class="message-wrapper {{item.role}}"
        wx:for="{{messageList}}" 
        wx:key="id"
        id="msg-{{item.id}}"
      >
        <!-- 头像 -->
        <view class="message-avatar">
          <text wx:if="{{item.role === 'user'}}">👤</text>
          <text wx:else>🤖</text>
        </view>
        
        <!-- 消息内容 -->
        <view class="message-content">
          <view class="message-bubble {{item.role}}">
            <text class="message-text">{{item.content}}</text>
          </view>
        </view>
      </view>

      <!-- 加载状态 -->
      <view class="message-wrapper ai" wx:if="{{isLoading}}" id="msg-loading">
        <view class="message-avatar">
          <text>🤖</text>
        </view>
        <view class="message-content">
          <view class="message-bubble ai loading">
            <view class="loading-dots">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
            </view>
            <text class="loading-text">思考中...</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部输入区域 -->
  <view class="input-area">
    <view class="input-wrapper">
      <textarea 
        class="input-field" 
        placeholder="输入消息..." 
        placeholder-class="input-placeholder"
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        confirm-type="send"
        maxlength="{{2000}}"
        auto-height
        show-confirm-bar="{{false}}"
        adjust-position="{{false}}"
        cursor-spacing="{{20}}"
      />
      <view class="input-actions">
        <text class="char-count">{{inputValue.length}}/2000</text>
        <view class="send-btn {{inputValue.trim() ? 'active' : ''}}" bindtap="sendMessage">
          <text class="send-icon">↑</text>
        </view>
      </view>
    </view>
  </view>
</view>
