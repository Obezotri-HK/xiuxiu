.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #E3F2FD 50%, #F0F7F4 100%);
  padding: 20rpx 32rpx 0 32rpx;
}

.user-section {
  margin-bottom: 30rpx;
}

.user-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(46, 204, 113, 0.1);
  border: 2rpx solid rgba(46, 204, 113, 0.4);
  border-radius: 60rpx;
  padding: 10rpx 24rpx 10rpx 12rpx;
}

.user-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.icon-circle {
  font-size: 36rpx;
  color: #2ECC71;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #27AE60;
  letter-spacing: 2rpx;
}

.user-badge-vip {
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.15) 0%, rgba(230, 126, 34, 0.1) 100%);
  border-color: rgba(243, 156, 18, 0.5);
}

.user-badge-vip .user-name {
  color: #E67E22;
}

.icon-vip {
  font-size: 32rpx;
}

.vip-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(90deg, rgba(243, 156, 18, 0.12) 0%, rgba(230, 126, 34, 0.08) 100%);
  border: 2rpx solid rgba(243, 156, 18, 0.25);
  border-radius: 60rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 30rpx;
}

.vip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.vip-text {
  flex: 1;
  font-size: 26rpx;
  color: #E67E22;
  font-weight: 500;
}

.vip-expire {
  font-size: 24rpx;
  color: rgba(230, 126, 34, 0.6);
}

.quota-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(46, 204, 113, 0.08);
  border: 2rpx solid rgba(46, 204, 113, 0.25);
  border-radius: 60rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 30rpx;
}

.quota-text {
  font-size: 26rpx;
  color: #7F8C8D;
}

.login-btn {
  font-size: 28rpx;
  color: #27AE60;
  font-weight: 500;
}

.location-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(46, 204, 113, 0.2);
  border-radius: 60rpx;
  padding: 22rpx 32rpx;
  margin-bottom: 50rpx;
}

.location-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #3498DB;
}

.location-text {
  font-size: 30rpx;
  color: #2C3E50;
  font-weight: 500;
}

.divider {
  width: 2rpx;
  height: 36rpx;
  background: rgba(46, 204, 113, 0.2);
  margin: 0 32rpx;
}

.weather-right {
  display: flex;
  align-items: center;
}

.weather-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.weather-text {
  font-size: 30rpx;
  color: #7F8C8D;
}

.hero-section {
  text-align: center;
  margin-bottom: 60rpx;
  position: relative;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500rpx;
  height: 300rpx;
  background: radial-gradient(ellipse, rgba(46, 204, 113, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.hero-title {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 20rpx;
}

.title-white {
  color: #2C3E50;
}

.title-gradient {
  background: linear-gradient(90deg, #2ECC71 0%, #3498DB 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  display: block;
  font-size: 32rpx;
  color: #7F8C8D;
  letter-spacing: 4rpx;
}

.bottom-placeholder {
  height: 280rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, transparent 0%, #F0F7F4 30%);
  padding: 20rpx 32rpx calc(40rpx + env(safe-area-inset-bottom)) 32rpx;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
  border-radius: 60rpx;
  flex-shrink: 0;
}

.action-btn-outline {
  background: rgba(46, 204, 113, 0.08);
  border: 2rpx solid rgba(46, 204, 113, 0.3);
}

.action-btn-purple {
  background: rgba(243, 156, 18, 0.12);
  border: 2rpx solid rgba(243, 156, 18, 0.4);
}

.action-btn-purple .action-icon,
.action-btn-purple .action-text {
  color: #E67E22;
}

.action-icon {
  font-size: 32rpx;
  color: #27AE60;
  margin-right: 10rpx;
}

.action-text {
  font-size: 28rpx;
  color: #27AE60;
  font-weight: 500;
}

.action-btn:last-child .action-icon {
  margin-right: 0;
}

.input-area {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(46, 204, 113, 0.2);
  border-radius: 60rpx;
  padding: 12rpx 16rpx 12rpx 32rpx;
}

.message-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #2C3E50;
}

.input-placeholder {
  color: #BDC3C7;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(46, 204, 113, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 20rpx;
  transition: all 0.3s ease;
}

.send-btn-active {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
}

.send-icon {
  font-size: 32rpx;
  color: rgba(46, 204, 113, 0.5);
  transform: rotate(-45deg);
}

.send-btn-active .send-icon {
  color: #ffffff;
}
