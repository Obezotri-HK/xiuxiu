/* 整体容器 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F8FA;
}

/* 顶部导航 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #E5E7EB;
  flex-shrink: 0;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}

.header-right {
  display: flex;
  align-items: center;
}

.header-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: #F3F4F6;
}

.header-icon {
  font-size: 28rpx;
  color: #4B5563;
  margin-right: 8rpx;
}

.header-text {
  font-size: 26rpx;
  color: #4B5563;
}

/* 消息列表 */
.chat-messages {
  flex: 1;
  padding: 32rpx 24rpx;
  overflow-anchor: auto;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #6B7280;
  text-align: center;
  padding: 0 60rpx;
  line-height: 1.6;
  margin-bottom: 60rpx;
}

/* 快捷提示 */
.quick-prompts {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  padding: 0 20rpx;
}

.prompt-item {
  padding: 20rpx 32rpx;
  background: #ffffff;
  border: 2rpx solid #E5E7EB;
  border-radius: 32rpx;
  max-width: 100%;
}

.prompt-text {
  font-size: 28rpx;
  color: #374151;
  white-space: nowrap;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
}

.message-wrapper {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.message-wrapper.user {
  flex-direction: row-reverse;
}

/* 头像 */
.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F6;
  font-size: 40rpx;
  flex-shrink: 0;
}

.message-wrapper.user .message-avatar {
  background: #ECFDF5;
}

/* 消息内容 */
.message-content {
  max-width: 580rpx;
  margin: 0 20rpx;
}

.message-bubble {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.7;
  word-break: break-word;
}

.message-bubble.user {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
}

.message-bubble.ai {
  background: #ffffff;
  color: #1F2937;
  border: 2rpx solid #E5E7EB;
  border-bottom-left-radius: 8rpx;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.7;
}

/* 加载状态 */
.message-bubble.loading {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  min-width: 160rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  margin-right: 16rpx;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #10B981;
  opacity: 0.4;
}

.loading-dots .dot:nth-child(1) {
  animation: dotPulse 1.4s infinite ease-in-out 0s;
}

.loading-dots .dot:nth-child(2) {
  animation: dotPulse 1.4s infinite ease-in-out 0.2s;
}

.loading-dots .dot:nth-child(3) {
  animation: dotPulse 1.4s infinite ease-in-out 0.4s;
}

.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    opacity: 0.4;
    transform: scale(0.8);
  }
  40% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 底部输入区域 */
.input-area {
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)) 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #E5E7EB;
  flex-shrink: 0;
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
  background: #F3F4F6;
  border-radius: 48rpx;
  padding: 16rpx 16rpx 16rpx 28rpx;
  min-height: 96rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #1F2937;
  line-height: 1.5;
  max-height: 200rpx;
  padding: 0;
}

.input-placeholder {
  color: #9CA3AF;
}

.input-actions {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-right: 16rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
}

.send-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}
