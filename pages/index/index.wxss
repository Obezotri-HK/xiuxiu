/* 整体容器 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(138rpx + env(safe-area-inset-bottom));
  background: #F7F8FA;
}

/* 顶部按钮栏 */
.chat-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #E5E7EB;
  flex-shrink: 0;
}

.location-weather {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 20rpx;
}

.location-info {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.location-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.location-text {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 600;
}

.weather-info {
  display: flex;
  align-items: center;
}

.weather-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.weather-text {
  font-size: 24rpx;
  color: #6B7280;
  margin-right: 12rpx;
}

.temp-text {
  font-size: 24rpx;
  color: #F59E0B;
  font-weight: 500;
}

.header-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: #F3F4F6;
}

.header-icon {
  font-size: 28rpx;
  color: #4B5563;
  margin-right: 8rpx;
}

.header-text {
  font-size: 26rpx;
  color: #4B5563;
}

/* 消息列表 */
.chat-messages {
  flex: 1;
  padding: 32rpx 24rpx;
  min-height: 0;
  box-sizing: border-box;
  overflow-anchor: auto;
}

.chat-content {
  min-height: 100%;
  box-sizing: border-box;
}

.chat-content.has-messages {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #6B7280;
  text-align: center;
  padding: 0 32rpx;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

/* 快捷提示 */
.quick-prompts {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  padding: 0 20rpx;
}

.prompt-item {
  padding: 12rpx 20rpx;
  background: #ffffff;
  border: 2rpx solid #E5E7EB;
  border-radius: 24rpx;
  max-width: 100%;
}

.prompt-text {
  font-size: 24rpx;
  color: #374151;
  white-space: nowrap;
}

/* 底部快捷功能入口 */
.bottom-actions {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 20rpx;
  background: #ffffff;
  border-top: 1rpx solid #F3F4F6;
  border-bottom: 4rpx solid #F9FAFB;
}

.bottom-action-item {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #F3F4F6;
  border-radius: 20rpx;
  text-align: center;
  transition: all 0.2s;
}

.bottom-action-item:active {
  background: #E5E7EB;
  transform: scale(0.98);
}

.bottom-action-text {
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

/* 录音遮罩 */
.recording-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  transition: all 0.2s;
}

.recording-mask.cancel {
  background: rgba(0, 0, 0, 0.8);
}

.recording-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 取消图标 */
.cancel-icon {
  font-size: 80rpx;
  color: #EF4444;
  margin-bottom: 32rpx;
  font-weight: bold;
}

/* 波浪动画 */
.wave-container {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.wave-bar {
  width: 12rpx;
  height: 60rpx;
  background: linear-gradient(180deg, #10B981 0%, #059669 100%);
  border-radius: 6rpx;
  animation: wave 0.8s infinite ease-in-out;
}

.wave-bar:nth-child(1) { animation-delay: 0s; }
.wave-bar:nth-child(2) { animation-delay: 0.1s; }
.wave-bar:nth-child(3) { animation-delay: 0.2s; }
.wave-bar:nth-child(4) { animation-delay: 0.3s; }
.wave-bar:nth-child(5) { animation-delay: 0.4s; }

@keyframes wave {
  0%, 100% { height: 20rpx; }
  50% { height: 80rpx; }
}

.recording-text {
  color: #ffffff;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.recording-hint {
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
}

/* 语音模式 */
.voice-mode {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 0;
}

.big-voice-btn {
  flex: 1;
  background: #1F2937;
  border-radius: 48rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: all 0.2s;
}

.big-voice-btn:active,
.big-voice-btn.recording {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  transform: scale(0.98);
}

.big-voice-icon {
  font-size: 40rpx;
}

.big-voice-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

/* 切换模式按钮 */
.switch-mode-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.switch-mode-btn:active {
  background: #E5E7EB;
  transform: scale(0.95);
}

.switch-icon {
  font-size: 40rpx;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  min-height: 100%;
  justify-content: flex-end;
}

.chat-bottom-anchor {
  height: 24rpx;
  flex-shrink: 0;
}

.message-wrapper {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.message-wrapper.user {
  flex-direction: row-reverse;
}

/* 头像 */
.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F6;
  font-size: 40rpx;
  flex-shrink: 0;
}

.message-wrapper.user .message-avatar {
  background: #ECFDF5;
}

/* 消息内容 */
.message-content {
  max-width: 580rpx;
  margin: 0 20rpx;
}

.message-bubble {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.7;
  word-break: break-word;
}

.message-bubble.user {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
}

.message-bubble.ai {
  background: #ffffff;
  color: #1F2937;
  border: 2rpx solid #E5E7EB;
  border-bottom-left-radius: 8rpx;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.7;
}

.recommend-section {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 2rpx solid #E5E7EB;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
}

.recommend-head {
  margin-bottom: 14rpx;
  padding: 0 2rpx;
}

.recommend-head-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ECFDF5;
  color: #059669;
  font-size: 22rpx;
  font-weight: 600;
}

.recommend-head-text {
  display: block;
  margin-top: 8rpx;
  color: #4B5563;
  font-size: 24rpx;
  line-height: 1.5;
}

.recommend-scroll {
  width: 100%;
  margin: 0 -2rpx;
}

.recommend-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 2rpx 2rpx;
}

.recommend-card {
  position: relative;
  width: 320rpx;
  background: linear-gradient(180deg, #1b2433 0%, #000000 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.2);
  flex-shrink: 0;
}

.recommend-image {
  width: 320rpx;
  height: 236rpx;
  background: #1F2937;
}

.recommend-image-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 236rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.06) 0%, rgba(15, 23, 42, 0.44) 100%);
}

.recommend-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  z-index: 2;
}

.recommend-body {
  padding: 18rpx 18rpx 20rpx;
}

.recommend-name {
  display: block;
  font-size: 28rpx;
  line-height: 1.4;
  color: #F9FAFB;
  font-weight: 600;
}

.recommend-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(229, 231, 235, 0.74);
  min-height: 66rpx;
}

.recommend-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.recommend-price {
  display: flex;
  align-items: baseline;
  color: #FB923C;
}

.recommend-price-sign {
  font-size: 22rpx;
  margin-right: 4rpx;
}

.recommend-price-num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.recommend-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(16, 185, 129, 0.16);
  color: #6EE7B7;
  font-size: 22rpx;
  font-weight: 600;
}

/* 加载状态 */
.message-bubble.loading {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  min-width: 160rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  margin-right: 16rpx;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #10B981;
  opacity: 0.4;
}

.loading-dots .dot:nth-child(1) {
  animation: dotPulse 1.4s infinite ease-in-out 0s;
}

.loading-dots .dot:nth-child(2) {
  animation: dotPulse 1.4s infinite ease-in-out 0.2s;
}

.loading-dots .dot:nth-child(3) {
  animation: dotPulse 1.4s infinite ease-in-out 0.4s;
}

.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    opacity: 0.4;
    transform: scale(0.8);
  }
  40% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 底部输入区域 */
.input-area {
  padding: 8rpx 20rpx 8rpx;
  background: #ffffff;
  border-top: 1rpx solid #F3F4F6;
  flex-shrink: 0;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F9FAFB;
  border: 2rpx solid #F3F4F6;
  border-radius: 48rpx;
  padding: 16rpx 16rpx 16rpx 28rpx;
  min-height: 96rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #1F2937;
  line-height: 1.5;
  max-height: 200rpx;
  padding: 0;
}

.input-placeholder {
  color: #9CA3AF;
}

.input-actions {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-right: 16rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
}

.send-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}
